{
  "name": "medien-suche",
  "version": "0.1.0",
  "description": "Windows Desktop-App zum Indexieren und Vergleichen von Plex-, PC-, NAS- und USB-Medien.",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc -p tsconfig.node.json && tsc -p tsconfig.web.json && electron-vite build",
    "typecheck": "tsc -p tsconfig.node.json && tsc -p tsconfig.web.json",
    "test": "vitest run --pool=threads",
    "preview": "electron-vite preview"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "electron-vite": "^3.0.0",
    "fuse.js": "^7.1.0",
    "lucide-react": "^0.562.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "@types/sql.js": "^1.4.9",
    "electron": "^33.2.1",
    "typescript": "^5.9.3",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  }
}
